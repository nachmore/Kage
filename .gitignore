# Rust
target/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Sample data
sample_sessions/

# Vendor node_modules and generated lib (run `npm install` in ui/vendor/ to populate)
ui/vendor/node_modules/
ui/vendor/lib/

# Test dependencies
ui/tests/node_modules/

# Python cache
__pycache__/
*.pyc

# Logs and local app data
*.log
logs/

# User config / secrets — never commit real values
config.json
.env
.env.*
!.env.example
# Aptabase analytics key — read by build.rs, never commit the real key
.aptabase-key

# Root-level local-only directories
node_modules/
www/
.claude/

# Agent scratch — todos, migration notes, anything not ready for commit
.agent/
# Staging dir for build.rs-compiled sidecar binaries (e.g. the macOS
# EventKit calendar helper) — rebuilt on every `cargo build` on macOS.
src-tauri/macos/bin/
