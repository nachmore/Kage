# Rust
target/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Sample data
sample_sessions/

# Vendor node_modules (use vendor/lib for committed files)
ui/vendor/node_modules/

# Test dependencies
ui/tests/node_modules/

# Python cache
__pycache__/
*.pyc

# Logs and local app data
*.log
logs/

# User config / secrets — never commit real values
config.json
.env
.env.*
!.env.example
# Aptabase analytics key — read by build.rs, never commit the real key
.aptabase-key
# Tauri updater public key — read by build.rs. Not secret (it ships in
# every binary) but kept out of source control so third-party forks
# don't accidentally inherit our trust anchor. The matching PRIVATE key
# lives only in CI secrets.
.tauri-updater-pubkey

# Root-level local-only directories
node_modules/
www/
.claude/

# Agent scratch — todos, migration notes, anything not ready for commit
.agent/
# Staging dir for build.rs-compiled sidecar binaries (e.g. the macOS
# EventKit calendar helper) — rebuilt on every `cargo build` on macOS.
src-tauri/macos/bin/
