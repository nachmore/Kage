# Rust
target/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Sample data
sample_sessions/

# Vendor lib output (browser bundles copied in by ui-vendor/setup.js).
# Regenerated on first dev/build via scripts/ensure_vendor.py.
ui/vendor/lib/

# Vendor and test npm tooling — kept outside ui/ so package.json and
# node_modules don't get brotli-embedded by tauri-codegen into the
# shipped binary. Run `npm install` in either dir to populate.
ui-vendor/node_modules/
ui-tests/node_modules/

# Python cache
__pycache__/
*.pyc

# Logs and local app data
*.log
logs/

# User config / secrets — never commit real values
config.json
.env
.env.*
!.env.example
# Aptabase analytics key — read by build.rs, never commit the real key
.aptabase-key

# Root-level local-only directories
node_modules/
www/
.claude/

# Agent scratch — todos, migration notes, anything not ready for commit
.agent/
# Temporary work plans — safe space for in-progress planning docs
docs/plans/
# Target-specific Tauri sidecars staged by build.rs (provision_sidecar):
# the MCP server on all platforms, the EventKit calendar helper on macOS.
src-tauri/binaries/

# Husky's internal runner scaffolding. The actual hooks (.husky/pre-push
# etc.) ARE checked in; the _/ subdir is regenerated by `npm install`
# via the `prepare` script.
.husky/_/
