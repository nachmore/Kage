{
  "id": "timer",
  "name": "Timer & Stopwatch",
  "version": "1.0.0",
  "type": "extension",
  "description": "Countdown timer and stopwatch with notification sounds",
  "icon": "⏱️",
  "author": "kage",

  "config": {
    "enabled": { "type": "boolean", "default": true },
    "notify_on_complete": { "type": "boolean", "default": true },
    "sound_on_complete": { "type": "boolean", "default": true },
    "sound_id": { "type": "string", "default": "two-tone" },
    "custom_sound_path": { "type": "string", "default": "" },
    "sound_repeats": { "type": "number", "default": 3 },
    "show_window_on_complete": { "type": "boolean", "default": true }
  },

  "contributes": {
    "searchProvider": "./search.js",
    "settingsModule": "./settings.js",
    "widgets": [
      {
        "id": "timer-bar",
        "slot": "floating-bottom",
        "module": "./timer-bar.js"
      }
    ]
  }
}
