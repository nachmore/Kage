{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "./ui",
    "distDir": "./ui",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Kiro Assistant",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "globalShortcut": {
        "all": true
      },
      "window": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.kiro.assistant",
      "icon": [
        "ui/assets/ghost.png",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "systemTray": {
      "iconPath": "ui/assets/ghost.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "Kiro Assistant",
        "width": 800,
        "height": 600,
        "visible": false,
        "skipTaskbar": false
      },
      {
        "label": "floating",
        "url": "floating.html",
        "fullscreen": false,
        "resizable": true,
        "minWidth": 500,
        "minHeight": 60,
        "title": "Kiro",
        "width": 500,
        "height": 60,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false
      },
      {
        "label": "settings",
        "url": "settings.html",
        "fullscreen": false,
        "resizable": true,
        "title": "Settings - Kiro Assistant",
        "width": 800,
        "height": 700,
        "visible": false,
        "skipTaskbar": false,
        "center": true
      }
    ]
  }
}
