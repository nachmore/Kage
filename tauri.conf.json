{
  "productName": "Kiro Assistant",
  "version": "0.2.0",
  "identifier": "com.kiro.assistant",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "./ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },

    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "Chat Sessions - Kiro Assistant",
        "width": 800,
        "height": 600,
        "visible": false,
        "skipTaskbar": false,
        "dragDropEnabled": false
      },
      {
        "label": "floating",
        "url": "floating.html",
        "fullscreen": false,
        "resizable": false,
        "minWidth": 516,
        "minHeight": 76,
        "title": "Kiro",
        "width": 516,
        "height": 76,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false,
        "dragDropEnabled": false
      },
      {
        "label": "settings",
        "url": "settings.html",
        "fullscreen": false,
        "resizable": true,
        "title": "Settings - Kiro Assistant",
        "width": 800,
        "height": 700,
        "minWidth": 600,
        "minHeight": 450,
        "visible": false,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "context-menu",
        "url": "context-menu.html",
        "fullscreen": false,
        "resizable": false,
        "title": "",
        "width": 160,
        "height": 220,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "shortDescription": "AI assistant with floating window interface",
    "longDescription": "Kiro Assistant is a cross-platform desktop AI assistant with a floating window interface, system tray integration, and custom command shortcuts.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "headerImage": "icons/nsis-header.bmp"
      }
    }
  }
}
