{
  "productName": "Kiro Assistant",
  "version": "0.1.0",
  "identifier": "com.kiro.assistant",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "./ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "ui/assets/ghost.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "Kiro Assistant",
        "width": 800,
        "height": 600,
        "visible": false,
        "skipTaskbar": false
      },
      {
        "label": "floating",
        "url": "floating.html",
        "fullscreen": false,
        "resizable": true,
        "minWidth": 516,
        "minHeight": 76,
        "title": "Kiro",
        "width": 516,
        "height": 76,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false
      },
      {
        "label": "settings",
        "url": "settings.html",
        "fullscreen": false,
        "resizable": true,
        "title": "Settings - Kiro Assistant",
        "width": 800,
        "height": 700,
        "visible": false,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "context-menu",
        "url": "context-menu.html",
        "fullscreen": false,
        "resizable": false,
        "title": "",
        "width": 160,
        "height": 220,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "ui/assets/ghost.png",
      "icons/icon.ico"
    ]
  }
}
