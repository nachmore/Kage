{
  "productName": "Kage",
  "identifier": "com.kage.launcher",
  "build": {
    "beforeDevCommand": "python scripts/dev_server.py",
    "beforeBuildCommand": "python scripts/build_mcp.py",
    "devUrl": "http://localhost:1420",
    "frontendDist": "./ui"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "Chat Sessions - Kage",
        "width": 800,
        "height": 600,
        "visible": false,
        "skipTaskbar": false,
        "dragDropEnabled": false
      },
      {
        "label": "floating",
        "url": "floating.html",
        "fullscreen": false,
        "resizable": false,
        "minWidth": 570,
        "minHeight": 76,
        "title": "Kage",
        "width": 570,
        "height": 76,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false,
        "dragDropEnabled": false
      },
      {
        "label": "inline-assist",
        "url": "inline-assist.html",
        "fullscreen": false,
        "resizable": false,
        "title": "",
        "width": 360,
        "height": 280,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": true
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDNUQzRkE4NUI4NTk3RkYKUldUL2w0VmJxRDlkTEFEQ3hJUk5ZK3RpK3BFYksyaGYwbTNjQ09uaDFURkp1VnlxK3FrN3VjMnc="
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "app",
      "dmg"
    ],
    "createUpdaterArtifacts": true,
    "resources": [
      "pocket_tts/*",
      "store/packages/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/kage.ico",
      "icons/kage.icns"
    ],
    "shortDescription": "AI powered launcher",
    "longDescription": "Kage is a cross-platform desktop AI interface with a floating window, system tray integration, and custom command shortcuts.",
    "publisher": "Oren Nachman",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "./src-tauri/macos/entitlements.plist",
      "infoPlist": "./src-tauri/macos/Info.plist",
      "exceptionDomain": "",
      "frameworks": []
    },
    "externalBin": [
      "src-tauri/macos/bin/kage-calendar-helper"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "headerImage": "icons/nsis-header.bmp",
        "installerHooks": "./src-tauri/windows/hooks.nsh",
        "template": "./src-tauri/windows/installer.nsi"
      }
    }
  }
}
