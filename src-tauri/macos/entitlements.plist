<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Kage macOS entitlements — embedded into the signed .app by tauri-bundler.
  Wired via `bundle.macOS.entitlements` in ../../tauri.conf.json.

  Only add entitlements we actually use; hardened runtime rejects anything
  not whitelisted here at runtime.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <key>com.apple.security.device.audio-input</key>
    <true/>

    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
