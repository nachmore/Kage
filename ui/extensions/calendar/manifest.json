{
  "id": "calendar",
  "name": "Calendar",
  "version": "1.0.0",
  "type": "extension",
  "description": "Show upcoming meetings with join button overlay",
  "icon": "📅",
  "author": "kage",

  "permissions": ["calendar", "shell", "automation"],

  "config": {
    "enabled": { "type": "boolean", "default": false },
    "show_overlay": { "type": "boolean", "default": true },
    "lookahead_hours": { "type": "number", "default": 8 }
  },

  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js",
    "toolProvider": "./tools.js",
    "triggerProvider": "./triggers.js",
    "widgets": [
      {
        "id": "next-meeting",
        "slot": "floating-bottom",
        "module": "./widget.js"
      }
    ]
  }
}
