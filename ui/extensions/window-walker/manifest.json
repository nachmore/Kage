{
  "id": "window-walker",
  "name": "Window Walker",
  "version": "1.0.0",
  "type": "extension",
  "description": "Switch between open windows. Type 'w ' to list and filter windows.",
  "icon": "🪟",
  "author": "kage",

  "config": {
    "enabled": { "type": "boolean", "default": true },
    "trigger": { "type": "string", "default": "w " }
  },

  "contributes": {
    "searchProvider": "./search.js",
    "settingsModule": "./settings.js"
  }
}
