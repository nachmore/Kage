{
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "ui/**/*.js",
      "ui/**/*.mjs",
      "ui/**/*.html",
      "ui/**/*.css",
      "ui/**/*.json",
      "!**/node_modules/**",
      "!ui/vendor/**",
      "!ui/extensions/**",
      "!store/**",
      "!ui/**/*.min.js",
      "!ui/**/*.min.css"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 4,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5",
      "semicolons": "always",
      "arrowParentheses": "always"
    },
    "globals": [
      "Tauri",
      "marked",
      "mermaid",
      "Prism",
      "math",
      "kageLog",
      "escapeHtml",
      "SettingsModule"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noConsole": "off",
        "noAssignInExpressions": "off",
        "useIterableCallbackReturn": "off",
        "noShadowRestrictedNames": "off"
      },
      "style": {
        "useConst": "warn",
        "useTemplate": "off",
        "noNonNullAssertion": "off",
        "noDescendingSpecificity": "off"
      },
      "complexity": {
        "noForEach": "off",
        "useArrowFunction": "off",
        "noImportantStyles": "off"
      },
      "correctness": {
        "noUnusedVariables": "off",
        "noUnusedFunctionParameters": "off",
        "noUnusedImports": "warn"
      },
      "performance": {
        "noDelete": "off"
      },
      "a11y": {
        "useButtonType": "off",
        "noSvgWithoutTitle": "off"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "off"
      }
    }
  }
}
